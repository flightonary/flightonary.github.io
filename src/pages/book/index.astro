---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';

const bookEntries = await getCollection('book');
bookEntries.sort((a, b) => a.data.title.localeCompare(b.data.title));
---

<BaseLayout subtitle="読書メモ一覧 - Pseudo Engineer" activeTab="book">
  <div class="main-layout">
    <main class="content">
      <section class="archive-page">
        <h2>読書メモ</h2>
        <div class="all-posts-list">
          {bookEntries.map(entry => (
            /* 💡 entry.slug から entry.id に変更 */
            <a href={`/book/${entry.id}`} class="all-post-item" style="text-decoration: none; color: inherit;">
              <span class="all-post-date">📖 Memo</span>
              <span class="all-post-title">{entry.data.title}</span>
            </a>
          ))}
        </div>
      </section>
    </main>
  </div>
</BaseLayout>